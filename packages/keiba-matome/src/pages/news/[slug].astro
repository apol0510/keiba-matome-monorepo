---
// SSG（静的生成）モード
// ビルド時にAirtableからデータ取得 → 静的HTML生成 → CDN配信
// リクエスト時にAirtableを呼ばないため502が発生しない
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllNews, getLatestNews } from '../../lib/news';
import { config } from '../../config';

// ビルド時に全記事のパスを生成（コメントはクライアント側で取得）
export async function getStaticPaths() {
  let articles = [];
  try {
    articles = await getAllNews();
  } catch (error) {
    console.error('getStaticPaths: 記事取得失敗', error);
    return [];
  }

  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;

// 構造化データ（JSON-LD）
const structuredData = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": article.title,
  "description": article.excerpt || article.title,
  "image": article.ogImage || `${config.siteUrl}/og/default.png`,
  "datePublished": article.publishedAt.toISOString(),
  "dateModified": article.publishedAt.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "競馬ニュースまとめ",
    "url": config.siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "競馬ニュースまとめ",
    "url": config.siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${config.siteUrl}/og/default.png`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${config.siteUrl}/news/${article.slug}/`
  },
  "commentCount": 0,
  "articleSection": article.category || "競馬ニュース",
  "keywords": article.tags?.join(', ') || "競馬",
  "inLanguage": "ja-JP"
};

// 関連記事を取得（ビルド時に解決済み）
let relatedArticles = [];
try {
  const allArticles = await getLatestNews(10);
  relatedArticles = allArticles
    .filter(a => a.slug !== article.slug && a.category === article.category)
    .slice(0, 3);
} catch (error) {
  console.warn('関連記事の取得に失敗しました');
}

const siteUrl = config.siteUrl;
const articleUrl = `${siteUrl}/news/${article.slug}/`;

// Markdownを簡易的にHTMLに変換
function markdownToHtml(markdown: string): string {
  return markdown
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(.+)$/gm, '<p>$1</p>')
    .replace(/<\/p><p><h([1-3])>/g, '</p><h$1>')
    .replace(/<\/h([1-3])><\/p>/g, '</h$1>');
}

const htmlContent = markdownToHtml(article.content);

// 常にローカル生成の構造化データを使用（Airtableの古いデータにauthor.url欠落があるため）
const finalStructuredData = JSON.stringify(structuredData);
---

<BaseLayout
  title={article.title}
  description={article.excerpt || article.title}
  ogImage={`/og/articles/${article.slug}.png`}
  metaTitle={article.metaTitle}
  metaDescription={article.metaDescription}
  ogTitle={article.ogTitle}
  ogDescription={article.ogDescription}
  keywords={article.keywords}
  structuredData={finalStructuredData}
>
  <!-- モバイル対応CSS -->
  <style>
    /* レスポンシブ対応 */
    .comment-header {
      font-size: 11px;
      color: #666;
      margin-bottom: 6px;
      word-wrap: break-word;
    }
    .comment-content {
      font-size: 13px;
      line-height: 1.6;
      white-space: pre-wrap;
      word-wrap: break-word;
    }
    .comment-form-input {
      width: 100%;
      padding: 8px;
      border: 1px solid #999;
      font-size: 14px;
      font-family: inherit;
      box-sizing: border-box;
    }
    .comment-form-textarea {
      width: 100%;
      padding: 8px;
      border: 1px solid #999;
      font-size: 14px;
      font-family: inherit;
      resize: vertical;
      box-sizing: border-box;
      min-height: 100px;
    }
    .submit-button {
      padding: 10px 20px;
      background-color: #ea8b00;
      color: #fff;
      border: 1px solid #999;
      font-size: 14px;
      cursor: pointer;
      width: 100%;
      max-width: 200px;
    }

    /* タブレット以上 */
    @media (min-width: 768px) {
      .comment-form-input {
        max-width: 300px;
        font-size: 12px;
        padding: 4px;
      }
      .comment-form-textarea {
        max-width: 600px;
        font-size: 12px;
        padding: 4px;
        min-height: 80px;
      }
      .submit-button {
        padding: 6px 16px;
        font-size: 12px;
        width: auto;
      }
    }
  </style>

  <!-- 構造化データ（DiscussionForumPosting） — commentCountはクライアント側で更新 -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DiscussionForumPosting",
    "headline": article.title,
    "text": article.excerpt || article.title,
    "datePublished": new Date(article.publishedAt).toISOString(),
    "url": articleUrl,
    "commentCount": 0,
    "discussionUrl": articleUrl,
    "author": {
      "@type": "Person",
      "name": "名無しさん@競馬板",
      "url": siteUrl
    },
    "publisher": {
      "@type": "Organization",
      "name": config.name,
      "url": siteUrl
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": articleUrl
    }
  })} />

  <!-- スレッド情報 -->
  <div style="background-color: #e6e6dc; border: 1px solid #999; padding: 12px; margin-bottom: 16px;">
    <h1 style="margin: 0 0 8px 0; font-size: 16px; font-weight: bold;">{article.title}</h1>
    <p style="margin: 0; font-size: 11px; color: #666;">
      カテゴリ: {article.category} |
      公開日: {new Date(article.publishedAt).toLocaleDateString('ja-JP')} |
      レス数: <span id="comment-count">...</span>件
    </p>
  </div>

  <!-- レス一覧（クライアント側で動的取得） -->
  <div class="comment-list" style="background-color: #fff; border: 1px solid #999; margin-bottom: 16px;">
    <div id="comments-loading" style="padding: 12px; text-align: center; color: #666;">
      コメント読み込み中...
    </div>
  </div>

  <!-- CTA: 記事下バナー -->
  <div style="background-color: #fff3cd; border: 2px solid #ea8b00; padding: 16px; margin: 16px 0; text-align: center;">
    <p style="margin: 0 0 8px 0; font-size: 16px; font-weight: bold; color: #ea8b00;">
      🏇 このニュースについてもっと知りたい方へ
    </p>
    <p style="margin: 0 0 12px 0; font-size: 13px; color: #666; line-height: 1.6;">
      競馬予想サイトの口コミ・評判を500サイト以上掲載中<br />
      詐欺サイトを避けて、本当に当たるサイトを見つけよう
    </p>
    <a href="https://keiba-review.jp/"
       target="_blank"
       rel="noopener"
       style="display: inline-block; padding: 12px 32px; background-color: #ea8b00; color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 14px;">
      無料で口コミを見る →
    </a>
  </div>

  <!-- 元記事リンク -->
  {article.excerpt && (
    <div style="background-color: #fff; border: 1px solid #999; padding: 12px; margin-bottom: 16px;">
      <p style="margin: 0 0 4px 0; font-size: 11px; color: #666; font-weight: bold;">
        ※元記事より
      </p>
      <p style="margin: 0 0 8px 0; font-size: 13px; line-height: 1.6; color: #333;">
        {article.excerpt.substring(0, 80)}{article.excerpt.length > 80 ? '...' : ''}
      </p>
      <a href={article.sourceURL || '#'}
         target="_blank"
         rel="noopener"
         style="color: #0000ff; text-decoration: none; font-size: 12px;">
        → 元記事を読む{article.sourceSite ? `（${article.sourceSite}）` : ''}
      </a>
    </div>
  )}

  <!-- レス投稿フォーム -->
  <div id="comment-form" style="background-color: #e6e6dc; border: 1px solid #999; padding: 12px; margin-bottom: 16px;">
    <p style="margin: 0 0 8px 0; font-size: 14px; font-weight: bold;">書き込む</p>

    <!-- メッセージ表示エリア（動的） -->
    <div id="message-area"></div>

    <form id="submit-form" style="display: flex; flex-direction: column; gap: 12px;">
      <div>
        <label for="userName" style="font-size: 12px; color: #666; display: block; margin-bottom: 4px;">名前:</label>
        <input
          type="text"
          id="userName"
          name="userName"
          placeholder="名無しさん@競馬板"
          class="comment-form-input"
        />
      </div>
      <div>
        <label for="content" style="font-size: 12px; color: #666; display: block; margin-bottom: 4px;">本文:</label>
        <textarea
          id="content"
          name="content"
          placeholder="コメントを入力... (2-500文字)"
          class="comment-form-textarea"
          required
        ></textarea>
      </div>
      <!-- Cloudflare Turnstile CAPTCHA -->
      <div id="cf-turnstile" class="cf-turnstile" data-sitekey="1x00000000000000000000AA" data-theme="light"></div>
      <div>
        <button
          type="submit"
          class="submit-button"
        >
          書き込む
        </button>
      </div>
    </form>
  </div>

  <!-- 注意書き -->
  <div style="margin-top: 16px; padding: 12px; background-color: #fff3cd; border: 1px solid #ffc107; font-size: 11px; color: #856404;">
    <p style="margin: 0 0 4px 0; font-weight: bold;">⚠️ 注意事項</p>
    <p style="margin: 0;">
      ・このスレッドのコメントの一部はAIによって自動生成されています。<br />
      ・投稿されたコメントはスパム判定後、即座に表示されます。<br />
      ・URLを含むコメントは投稿できません。
    </p>
  </div>

  <!-- スレッド一覧に戻る -->
  <div style="margin-top: 16px; text-align: center;">
    <a href="/" style="color: #0000ff; text-decoration: none; font-size: 12px;">
      ← スレッド一覧に戻る
    </a>
  </div>

  <!-- コメント取得 + 投稿 + 即時反映スクリプト -->
  <script define:vars={{ articleId: article.id }}>
    const commentList = document.querySelector('.comment-list');
    const commentCountEl = document.getElementById('comment-count');
    const form = document.getElementById('submit-form');
    const messageArea = document.getElementById('message-area');

    // 相対時間フォーマット
    function formatTime(dateStr) {
      const date = new Date(dateStr);
      const now = new Date();
      const diff = now.getTime() - date.getTime();
      const minutes = Math.floor(diff / (1000 * 60));
      const hours = Math.floor(diff / (1000 * 60 * 60));
      const days = Math.floor(hours / 24);

      if (minutes < 1) return 'たった今';
      if (hours < 1) return minutes + '分前';
      if (hours < 24) return hours + '時間前';
      if (days < 7) return days + '日前';

      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      const dow = ['日','月','火','水','木','金','土'][date.getDay()];
      return y + '/' + m + '/' + d + '(' + dow + ')';
    }

    // HTMLエスケープ
    function esc(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    // コメントHTML生成
    function renderComment(c) {
      const bg = c.number % 2 === 0 ? '#fafafa' : '#fff';
      const opBadge = c.isOP
        ? '<span style="margin-left:4px;padding:1px 4px;background-color:#ea8b00;color:#fff;font-size:9px;border-radius:2px;">スレ主</span>'
        : '';
      return '<div id="res' + c.number + '" style="border-bottom:1px solid #ddd;padding:12px;background-color:' + bg + ';">'
        + '<div class="comment-header">'
        + '<span style="font-weight:bold;color:#000;">' + c.number + '</span>'
        + '<span style="margin-left:8px;">名前：' + esc(c.userName || '名無しさん@競馬板') + '</span>'
        + opBadge
        + '<span style="margin-left:8px;">' + formatTime(c.createdAt) + '</span>'
        + '<span style="margin-left:8px;">' + esc(c.userID) + '</span>'
        + '</div>'
        + '<div class="comment-content" style="margin-top:8px;line-height:1.6;white-space:pre-wrap;word-wrap:break-word;">'
        + esc(c.content)
        + '</div></div>';
    }

    // コメント取得（クライアント側）
    async function loadComments() {
      try {
        const res = await fetch('/api/comments?id=' + encodeURIComponent(articleId));
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        const comments = data.comments || [];

        commentCountEl.textContent = comments.length;
        if (comments.length === 0) {
          commentList.innerHTML = '<div style="padding:12px;text-align:center;color:#666;">まだコメントがありません</div>';
        } else {
          commentList.innerHTML = comments.map(renderComment).join('');
        }
      } catch (err) {
        console.error('コメント取得失敗:', err);
        commentCountEl.textContent = '-';
        commentList.innerHTML = '<div style="padding:12px;text-align:center;color:#666;">コメントの読み込みに失敗しました</div>';
      }
    }

    loadComments();

    // フォーム送信処理
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const content = formData.get('content');
      const userName = formData.get('userName') || '名無しさん@競馬板';

      if (!content || content.length < 2) {
        showMessage('コメントは2文字以上入力してください', 'error');
        return;
      }
      if (content.length > 500) {
        showMessage('コメントは500文字以内で入力してください', 'error');
        return;
      }
      if (content.match(/https?:\/\//) || content.match(/www\./)) {
        showMessage('URLを含むコメントは投稿できません', 'error');
        return;
      }

      let turnstileToken = null;
      if (typeof turnstile !== 'undefined') {
        turnstileToken = turnstile.getResponse();
      }

      const submitButton = form.querySelector('button[type="submit"]');
      const originalButtonText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = '送信中...';

      try {
        const response = await fetch('/api/submit-comment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            newsId: articleId,
            content: content,
            userName: userName,
            captchaToken: turnstileToken,
          }),
        });

        let result;
        const contentType = response.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
          result = await response.json();
        } else {
          const text = await response.text();
          console.error('Non-JSON response:', text.substring(0, 200));
          throw new Error('サーバーエラーが発生しました');
        }

        if (!response.ok) {
          throw new Error(result.error || 'コメント投稿に失敗しました');
        }

        showMessage('コメントを投稿しました（レス番号: ' + result.comment.number + '）', 'success');

        // DOMに追加
        const newHtml = renderComment({
          number: result.comment.number,
          userName: result.comment.userName,
          userID: result.comment.userId,
          content: result.comment.content,
          isOP: false,
          createdAt: result.comment.createdAt,
        });

        // 「まだコメントがありません」を消す
        const empty = commentList.querySelector('[style*="text-align:center"]');
        if (empty && empty.textContent.includes('まだコメント')) {
          empty.remove();
        }

        commentList.insertAdjacentHTML('beforeend', newHtml);
        commentCountEl.textContent = parseInt(commentCountEl.textContent || '0') + 1;

        form.reset();

        setTimeout(() => {
          const el = document.getElementById('res' + result.comment.number);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            el.style.transition = 'background-color 0.3s';
            el.style.backgroundColor = '#fff9c4';
            setTimeout(() => { el.style.backgroundColor = ''; }, 3000);
          }
        }, 100);

      } catch (error) {
        console.error('Comment submission error:', error);
        showMessage(error.message, 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
      }
    });

    function showMessage(message, type) {
      const bgColor = type === 'success' ? '#d4edda' : '#f8d7da';
      const borderColor = type === 'success' ? '#c3e6cb' : '#f5c6cb';
      const textColor = type === 'success' ? '#155724' : '#721c24';
      messageArea.innerHTML = '<div style="background-color:' + bgColor + ';border:1px solid ' + borderColor + ';padding:12px;margin-bottom:12px;font-size:13px;color:' + textColor + ';">' + esc(message) + '</div>';
      setTimeout(() => { messageArea.innerHTML = ''; }, 5000);
    }
  </script>

</BaseLayout>
